{
  "id": null,
  "uid": "crypto-analytics-live-filled",
  "title": "Crypto Analytics - Live Filled Dashboard",
  "tags": ["crypto", "analytics", "filled", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Services UP",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(up)",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Service Availability",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Scrape Duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "scrape_duration_seconds",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Scraped Samples",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "scrape_samples_scraped",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Go Goroutines",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "go_goroutines",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory Usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Prometheus HTTP Requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(prometheus_http_requests_total[5m])",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Prometheus TSDB Head Series",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "prometheus_tsdb_head_series",
          "legendFormat": "series",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 }
    }
  ]
}
