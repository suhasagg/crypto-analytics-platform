{
  "id": null,
  "uid": "crypto-analytics-dummy-pro",
  "title": "Crypto Analytics Dummy Pro",
  "tags": ["crypto", "dummy-data", "fancy", "timeseries"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total TPS",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(crypto_tps)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 200 },
              { "color": "purple", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Indexed Transactions",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(crypto_transactions_indexed_total)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue", "value": 10000 },
              { "color": "purple", "value": 100000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Cache Hit Ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "avg(crypto_cache_hit_ratio) * 100", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Whale Transfers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(crypto_whale_transfers_total)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "red", "value": 500 },
              { "color": "purple", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "TPS by Chain",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "crypto_tps", "legendFormat": "{{chain}}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 3, "fillOpacity": 30, "gradientMode": "scheme", "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },
    {
